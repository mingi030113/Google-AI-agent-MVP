PORT=4000
STORE_DRIVER=json

# Supabase store settings, only needed when STORE_DRIVER=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_INSPECTION_IMAGE_BUCKET=inspection-images
SUPABASE_MANUAL_FILE_BUCKET=manual-files

# Vision settings
VISION_DRIVER=patchcore
PATCHCORE_MODEL_SERVICE_URL=http://127.0.0.1:8000
# Model service setting. Use PATCHCORE_ARTIFACT_ROOT for multi-class routing
# such as ../artifacts/bottle and ../artifacts/metal_nut.
PATCHCORE_ARTIFACT_ROOT=../artifacts
PATCHCORE_DEFAULT_ASSET_KEY=bottle
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-3-flash-preview

# Agent answer generation settings
# Use Gemini to turn RAG context into the final chatbot answer. When GEMINI_API_KEY is set,
# Agent answers are API-first unless AGENT_ANSWER_FORCE_LOCAL=true or AGENT_ANSWER_DRIVER=local-only.
# If Gemini fails or GEMINI_API_KEY is empty, the backend falls back to local RAG templates.
AGENT_ANSWER_DRIVER=gemini
AGENT_ANSWER_FORCE_LOCAL=false
GEMINI_AGENT_MODEL=gemini-3-flash-preview

# Report generation settings
# Use Gemini to turn computed inspection metrics into a structured quality report.
# If Gemini fails or GEMINI_API_KEY is empty, the backend falls back to a local structured report.
REPORT_GENERATION_DRIVER=gemini
GEMINI_REPORT_MODEL=gemini-3-flash-preview
